<UserControl x:Class="CCRSnap.Controls.MagnifierControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="RootBorder" BorderBrush="Gray" BorderThickness="1" Background="White"
            Width="210" Height="210" Visibility="Collapsed">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="CoordText" Grid.Row="0" Text="0,0" Foreground="Black"
                       FontSize="11" TextAlignment="Center" Margin="2"/>
            <Image x:Name="ZoomedImage" Grid.Row="1" Stretch="None"
                   Width="200" Height="200" Margin="0,0,0,0"/>
            <Canvas Grid.Row="1" Width="200" Height="200">
                <Line X1="100" Y1="0" X2="100" Y2="200" Stroke="Red" StrokeThickness="0.5"/>
                <Line X1="0" Y1="100" X2="200" Y2="100" Stroke="Red" StrokeThickness="0.5"/>
            </Canvas>
        </Grid>
    </Border>
</UserControl>
