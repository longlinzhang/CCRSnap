<Window x:Class="CCRSnap.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CCRSnap - 截图工具" Height="620" Width="860"
        WindowStartupLocation="CenterScreen" Icon="/CCRSnap;component/TC.ico"
        ShowInTaskbar="False" WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Foreground" Value="Navy"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="4,2"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top buttons row -->
        <Grid Grid.Row="0" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="BtnCapture" Content="手动截图 (Alt+A)" Click="BtnCapture_Click"
                        Width="110" Height="32" FontWeight="Bold" Background="DodgerBlue" Foreground="Black"/>
                <Button x:Name="BtnStart" Content="开始" Click="BtnStart_Click"
                        Width="65" Height="32" Foreground="Black" Background="ForestGreen"/>
                <Button x:Name="BtnStop" Content="停止" Click="BtnStop_Click"
                        Width="65" Height="32" IsEnabled="False" Background="IndianRed" Foreground="Black"/>
                <Button x:Name="BtnSave" Content="保存设置" Click="BtnSave_Click"
                        Width="75" Height="32"/>
                <Button x:Name="BtnCleanMem" Content="清理内存" Click="BtnCleanMem_Click"
                        Width="80" Height="32" Margin="4"/>
                <Button x:Name="BtnFormula" Content="公式计算" Click="BtnFormula_Click"
                        Width="75" Height="32"/>
                <Button x:Name="BtnFixHK" Content="修复热键" Click="BtnFixHK_Click"
                        Width="75" Height="32"/>
            </StackPanel>
            <Image Grid.Column="1" x:Name="LogoImage" Source="/CCRSnap;component/Resources/CNBM-TCDRI.png"
                   Width="180" Height="30" Margin="4,0" Stretch="Uniform"
                   Cursor="Hand" ToolTip="点击切换语言" MouseDown="LogoImage_MouseDown"/>
        </Grid>

        <!-- Main content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Left Column -->
                <GroupBox Grid.Row="0" Grid.Column="0" x:Name="GbxSchedule" Header="定时截图设置">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <RadioButton Grid.Row="0" x:Name="RbtnNow" Content="立即开始" IsChecked="True"
                                     GroupName="Schedule" Checked="Schedule_Changed"/>
                        <RadioButton Grid.Row="1" x:Name="RbtnTime" Content="指定时间"
                                     GroupName="Schedule" Checked="Schedule_Changed"/>
                        <StackPanel x:Name="TimePanel" Grid.Row="2" Orientation="Horizontal" Margin="20,0,0,0" Visibility="Collapsed">
                            <Label x:Name="LabelTime" Content="时间(HH:mm):" FontWeight="Normal"/>
                            <TextBox x:Name="TbxTime" Text="08:00" Width="80"/>
                        </StackPanel>
                        <RadioButton Grid.Row="3" x:Name="RbtnHourly" Content="每小时"
                                     GroupName="Schedule" Checked="Schedule_Changed"/>
                        <RadioButton Grid.Row="4" x:Name="RbtnHalfHour" Content="每半小时"
                                     GroupName="Schedule" Checked="Schedule_Changed"/>
                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,6,0,0">
                            <Label x:Name="LabelInterval" Content="间隔(秒):" FontWeight="Normal"/>
                            <TextBox x:Name="TbxInterval" Text="30" Width="70"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="0" x:Name="GbxFunctions" Header="功能选项">
                    <StackPanel>
                        <CheckBox x:Name="CbxScreenshot" Content="启用截图" IsChecked="True"/>
                        <CheckBox x:Name="CbxAutoCleanMem" Content="定时清理内存"/>
                        <CheckBox x:Name="CbxAutoDelete" Content="自动删除旧截图" IsChecked="True"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <Label x:Name="LabelDays" Content="保留天数:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxDays" Text="30" Width="50"/>
                        </StackPanel>
                        <CheckBox x:Name="CbxHide" Content="隐藏保存文件夹"/>
                        <CheckBox x:Name="CbxLogin" Content="开机启动"/>
                        <CheckBox x:Name="CbxAutoStart" Content="启动时自动开始"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Grid.Column="0" x:Name="GbxWecom" Header="企业微信推送">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" x:Name="CbxPushWecom" Content="推送截图到企微群"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,0,0">
                            <Label x:Name="LabelWebhook" Content="Webhook:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxWebhook" Width="200"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="4,8,4,4">
                            <TextBlock x:Name="HotkeyHelpBlock" FontWeight="Normal" TextWrapping="Wrap">
                                如果热键无效，点击"修复热键"重新注册快捷键。
                                Alt+A = 手动截图, Ctrl+F12 = 显示/隐藏, Ctrl+` = 全屏保存
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Right Column -->
                <GroupBox Grid.Row="0" Grid.Column="1" x:Name="GbxSaveSettings" Header="保存设置">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label x:Name="LabelSavePath" Content="保存路径:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxPath" Width="180"/>
                            <Button x:Name="BtnBrowse" Content="浏览" Width="60"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                            <RadioButton x:Name="RbtnSeparate" Content="单独保存" GroupName="CaptureMode" IsChecked="True"/>
                            <RadioButton x:Name="RbtnCombine" Content="合并保存" GroupName="CaptureMode"/>
                        </WrapPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <Label x:Name="LabelExtName" Content="文件后缀:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxExtName" Text="jpg" Width="50"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <Label x:Name="LabelPrefix" Content="文件前缀:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxPrefix" Width="120"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                            <Label x:Name="LabelQuality" Content="JPEG质量:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxQuality" Text="80" Width="50"/>
                        </StackPanel>
                        <GroupBox Grid.Row="5" x:Name="GbxFileFormat" Header="文件格式" FontWeight="Bold">
                            <WrapPanel>
                                <RadioButton x:Name="RbtnJpg" Content="JPG" GroupName="FileType" IsChecked="True"/>
                                <RadioButton x:Name="RbtnPng" Content="PNG" GroupName="FileType"/>
                                <RadioButton x:Name="RbtnGif" Content="GIF" GroupName="FileType"/>
                                <RadioButton x:Name="RbtnTif" Content="TIF" GroupName="FileType"/>
                                <RadioButton x:Name="RbtnBmp" Content="BMP" GroupName="FileType"/>
                            </WrapPanel>
                        </GroupBox>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Grid.Column="1" x:Name="GbxDetectSet" Header="差异检测设置">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" x:Name="CbxDetect" Content="检测屏幕变化" Checked="Detect_Changed"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,0,0">
                            <Label x:Name="LabelDiffRatio" Content="变化率阈值(%):" FontWeight="Normal"/>
                            <TextBox x:Name="TbxDiffRatio" Text="10" Width="60"/>
                            <Label x:Name="LabelTolerance" Content="容差:" FontWeight="Normal"/>
                            <TextBox x:Name="TbxTolerance" Text="10" Width="50"/>
                        </StackPanel>
                        <GroupBox Grid.Row="2" x:Name="GbxScreenIdx" Header="检测屏幕" FontWeight="Bold" Margin="20,4,4,4">
                            <WrapPanel>
                                <RadioButton x:Name="Screen0" Content="L" GroupName="ScreenIndex"/>
                                <RadioButton x:Name="Screen1" Content="R" GroupName="ScreenIndex" IsChecked="True"/>
                                <RadioButton x:Name="Screen2" Content="A" GroupName="ScreenIndex"/>
                                <RadioButton x:Name="Screen3" Content="B" GroupName="ScreenIndex"/>
                                <RadioButton x:Name="Screen4" Content="C" GroupName="ScreenIndex"/>
                                <RadioButton x:Name="Screen5" Content="D" GroupName="ScreenIndex"/>
                            </WrapPanel>
                        </GroupBox>
                    </Grid>
                </GroupBox>

                
                <GroupBox Grid.Row="2" Grid.Column="1" x:Name="GbxOcrConfig" Header="OCR/翻译配置">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label Content="SecretId:" FontWeight="Normal" Width="65"/>
                            <TextBox x:Name="TbxSecretId" Width="200"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Label Content="SecretKey:" FontWeight="Normal" Width="65"/>
                            <TextBox x:Name="TbxSecretKey" Width="200"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <Label Content="OCR模式:" FontWeight="Normal" Width="65"/>
                            <ComboBox x:Name="CboOcrApi" Width="200"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>

        <!-- Status bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem x:Name="StatusLeft" Content="就绪" MinWidth="200"/>
            <StatusBarItem HorizontalAlignment="Center">
                <TextBlock x:Name="StatusCount"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right" Foreground="Blue">
                <TextBlock x:Name="StatusRight"
                    Text="CCRSnap 天津水泥工业设计研究院有限公司 生产服务部 张龙林"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
