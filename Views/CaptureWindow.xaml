<Window x:Class="CCRSnap.Views.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:CCRSnap.Controls"
        WindowStyle="None" AllowsTransparency="True" WindowState="Normal"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        Cursor="Cross">
    <Canvas x:Name="MainCanvas" Background="Transparent">
        <!-- Selection rectangle drawn programmatically -->
        <Rectangle x:Name="SelectionRect" Stroke="Red" StrokeThickness="2"
                   Fill="#40000000" Visibility="Collapsed"/>
        <!-- Magnifier -->
        <ctrl:MagnifierControl x:Name="Magnifier"/>
    </Canvas>
</Window>
